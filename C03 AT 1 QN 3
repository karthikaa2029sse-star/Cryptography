from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.asymmetric import rsa, padding
from cryptography.exceptions import InvalidSignature


def generate_keys():
    """
    Generate RSA Private and Public Keys
    """
    private_key = rsa.generate_private_key(
        public_exponent=65537,
        key_size=2048
    )

    public_key = private_key.public_key()

    return private_key, public_key


def sign_message(private_key, message):
    """
    Sign a message using the RSA private key
    """
    signature = private_key.sign(
        message.encode(),
        padding.PSS(
            mgf=padding.MGF1(hashes.SHA256()),
            salt_length=padding.PSS.MAX_LENGTH
        ),
        hashes.SHA256()
    )

    return signature


def verify_signature(public_key, message, signature):
    """
    Verify the digital signature using the RSA public key
    """
    try:
        public_key.verify(
            signature,
            message.encode(),
            padding.PSS(
                mgf=padding.MGF1(hashes.SHA256()),
                salt_length=padding.PSS.MAX_LENGTH
            ),
            hashes.SHA256()
        )
        return True

    except InvalidSignature:
        return False


def main():

    print("=" * 60)
    print("RSA DIGITAL SIGNATURE SYSTEM")
    print("=" * 60)

    # Step 1: Generate RSA Key Pair
    print("\nGenerating RSA Key Pair...")
    private_key, public_key = generate_keys()
    print("RSA Keys Generated Successfully!")

    # Step 2: Input Message
    message = input("\nEnter a message to sign: ")

    # Step 3: Generate Digital Signature
    print("\nGenerating Digital Signature...")
    signature = sign_message(private_key, message)

    print("\nOriginal Message:")
    print(message)

    print("\nDigital Signature (Hex Format):")
    print(signature.hex())

    # Step 4: Verify Original Message
    print("\nVerifying Original Message...")

    if verify_signature(public_key, message, signature):
        print("✓ Signature Verification Successful")
        print("✓ Message is Authentic")
        print("✓ Integrity Maintained")
    else:
        print("✗ Signature Verification Failed")

    # Step 5: Demonstrate Tampering Detection
    print("\n" + "=" * 60)
    print("TAMPERING TEST")
    print("=" * 60)

    tampered_message = message + " MODIFIED"

    print("\nTampered Message:")
    print(tampered_message)

    print("\nVerifying Tampered Message...")

    if verify_signature(public_key, tampered_message, signature):
        print("✓ Signature Verified")
    else:
        print("✗ Signature Verification Failed")
        print("✗ Tampering Detected")
        print("✗ Integrity Compromised")

    print("\n" + "=" * 60)
    print("SECURITY FEATURES DEMONSTRATED")
    print("=" * 60)
    print("1. Authentication      ✓")
    print("2. Integrity           ✓")
    print("3. Non-Repudiation     ✓")
    print("4. Tampering Detection ✓")
    print("=" * 60)


if __name__ == "__main__":
    main()
